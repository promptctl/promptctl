{
  "name": "promptctl",
  "productName": "promptctl",
  "version": "1.0.0",
  "description": "My Electron application description",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "start": "tsx scripts/dev.ts",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx,css,html}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,css,html}'",
    "test": "vitest run && npm run test:e2e",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "pretest:e2e": "electron-forge package",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "schema:extract": "tsx scripts/schema/run.ts all",
    "schema:check": "tsx scripts/schema/run.ts all --check",
    "tokens:validate": "tsx scripts/validate-tokens.ts"
  },
  "keywords": [],
  "author": {
    "name": "Brandon Fryslie",
    "email": "530235+brandon-fryslie@users.noreply.github.com"
  },
  "license": "MIT",
  "dependencies": {
    "@types/diff": "^7.0.2",
    "@uiw/react-textarea-code-editor": "^3.1.1",
    "@promptctl/pane-terminal": "file:../tmux-control-mode-js/packages/pane-terminal",
    "@vscode/ripgrep": "^1.17.1",
    "@xterm/xterm": "^5.5.0",
    "diff": "^9.0.0",
    "electron-squirrel-startup": "^1.0.1",
    "openai": "^6.34.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.1",
    "tiktoken": "^1.0.22",
    "tmux-control-mode-js": "file:../tmux-control-mode-js",
    "undici": "^8.1.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/eslint__js": "^8.42.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "41.0.3",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.0.1",
    "playwright": "^1.59.1",
    "prettier": "^3.8.1",
    "selfsigned": "^5.5.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  }
}
